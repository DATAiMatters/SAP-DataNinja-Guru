# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=

# Resend API key. If unset, magic link is logged to the dev console
# instead of being emailed (handy for local development).
# https://resend.com
AUTH_RESEND_KEY=

# Sender address. "onboarding@resend.dev" works for the Resend account
# owner only. For production, set this to an address on a verified domain.
AUTH_RESEND_FROM=onboarding@resend.dev

# Local SQLite file. Swap to Postgres + drizzle-orm/postgres for prod.
DATABASE_URL=./data.db

# Used by Auth.js to construct callback URLs. Override per environment.
NEXTAUTH_URL=http://localhost:3000
